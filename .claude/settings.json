{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh scripts/check-dev-env.sh",
            "timeout": 10,
            "statusMessage": "Checking dev environment..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|MultiEdit|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun format; cargo fmt --manifest-path src-tauri/Cargo.toml",
            "statusMessage": "Formatting..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun lint && bun test && cargo test --manifest-path src-tauri/Cargo.toml",
            "timeout": 30,
            "statusMessage": "Running lint and tests..."
          }
        ]
      }
    ]
  }
}
